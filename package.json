{
  "name": "design-ontology",
  "version": "0.1.6",
  "description": "An open specification and toolchain for teaching AI agents why behind design decisions, not just what.",
  "type": "module",
  "bin": {
    "design-ontology": "dist/cli/index.js",
    "design-ontology-mcp": "dist/mcp/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./schema/design-ontology.schema.json"
  },
  "files": [
    "dist/",
    "schema/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "design-ontology",
    "mcp",
    "design-system",
    "ai",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaeldoye/design-ontology.git"
  },
  "homepage": "https://github.com/michaeldoye/design-ontology#readme",
  "author": "design-ontology contributors",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "openai": "^6.32.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "tsup": "^8.5.1",
    "typescript": "~5.8",
    "vitest": "^4.1.1"
  }
}
